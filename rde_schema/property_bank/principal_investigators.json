{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://archive.icpsr.umich.edu/schema/property_banks/principal_investigators",
  "title": "Principal Investigators",
  "description": "The key people or organizations responsible for the data collection, listed by importance. Each data collection requires at least one PI, either a person or an organization.",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "person": {
        "$ref": "https://archive.icpsr.umich.edu/schema/property_banks/person/version/1",
        "title": "Person",
        "description": "Name and other details about the principal investigator, if it is an individual person."
      },
      "organization": {
        "$ref": "https://archive.icpsr.umich.edu/schema/property_banks/organization/version/1",
        "title": "Organization",
        "description": "Name and other details about the principal investigator, if it is an organization."
      },
      "order": {
        "title": "Order",
        "description": "The order or rank of importance for the PIs associated with the data collection, typically provided to ICPSR by the lead PI.",
        "type": "integer",
        "examples": [0,1,2]
      }
    },
    "allOf": [
      {
        "oneOf": [
          { "required": ["person"] },
          { "required": ["organization"] }
        ]   
      },
      {
        "required": ["order"]
      }
    ]
  },
  "minItems": 1,
  "examples": [
    [
      {
        "person": {
          "name": {
            "given": "Jane",
            "family": "Smith"
          }
        },
        "order": 0
      }
    ],
    [
      {
        "person": {
          "name": {
            "given": "Joe Q.",
            "family": "Doe IV"
          },
          "orcid": "https://orcid.org/0000-0001-6666-5717",
          "affiliations": [
            {
              "name": "Urban Institute",
              "ror": "https://ror.org/017pz3h73",
              "icpsr_org_id": "xyz123"
            },
            {
              "name": "Example University"
            }
          ]
        },
        "order": 0
      },
      {
        "organization": 
          {
            "name": "New York Times",
            "ror": "https://ror.org/011w6k548"
          },
        "order": 1
      }
    ]
  ]
}